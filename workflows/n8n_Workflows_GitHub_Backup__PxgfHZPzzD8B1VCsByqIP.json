        64,
        -112
      ]
    },
    {
      "parameters": {
        "options": {}
      },
      "id": "f404a9a7-5185-4558-aab7-163489aac069",
      "name": "Loop por Workflow",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        320,
        -128
      ]
    },
    {
      "parameters": {
        "url": "=https://vdc.sersocial.org/n8n/api/v1/workflows/{{ $json.id }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-N8N-API-KEY",
              "value": "***REDACTED***"
            }
          ]
