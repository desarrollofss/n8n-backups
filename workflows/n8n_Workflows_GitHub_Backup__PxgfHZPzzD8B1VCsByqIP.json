    },
    {
      "parameters": {
        "jsCode": "// Extrae el array de workflows de la respuesta paginada de n8n\nconst data = $input.first().json.data || [];\nif (data.length === 0) {\n  throw new Error('No se encontraron workflows en n8n');\n}\nreturn data.map(w => ({ json: w }));"
      },
      "id": "04828363-67f5-492f-bda2-705ecfc19275",
      "name": "Extraer Lista",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
