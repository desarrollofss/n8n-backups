        "options": {}
      },
      "id": "539d88fd-9965-4596-a6fe-47bcf96d3f5d",
      "name": "GET Workflow Detalle",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        512,
        -128
      ]
    },
    {
      "parameters": {
        "jsCode": "const wf = $input.first().json;\n\nif (wf.nodes) {\n  wf.nodes = wf.nodes.map(node => {\n    if (node.parameters?.headerParameters?.parameters) {\n      node.parameters.headerParameters.parameters = \n        node.parameters.headerParameters.parameters.map(h => ({\n          ...h,\n          value: '***REDACTED***'\n        }));\n    }\n    return node;\n  });\n}\n\nconst nombre = wf.name\n  .replace(/[^a-zA-Z0-9_\\-áéíóúÁÉÍÓÚñÑ ]/g, '')\n  .trim()\n  .replace(/\\s+/g, '_') + '__' + wf.id;\n\nconst contenido = Buffer\n  .from(JSON.stringify(wf, null, 2))\n  .toString('base64');\n\nconst ahora = new Date().toISOString();\n\nreturn [{\n  json: {\n    workflow_id: wf.id,\n    workflow_name: wf.name,\n    github_path: `workflows/${nombre}.json`,\n    contenido_base64: contenido,\n    commit_msg: `backup: ${wf.name} [${wf.id}] - ${ahora}`\n  }\n}];"
      },
      "id": "9e0f4d35-6917-41d7-9703-121e7f499c45",
      "name": "Preparar Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        -128
      ]
    },
    {
      "parameters": {
        "url": "=https://api.github.com/repos/desarrollofss/n8n-backups/contents/{{ $json.github_path }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "***REDACTED***"
            },
            {
              "name": "Accept",
              "value": "***REDACTED***"
            }
          ]
        },
        "options": {}
      },
      "id": "2864318d-bccb-4e51-99ba-7f1ac8cc0ffa",
      "name": "GET SHA de GitHub",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        944,
        -128
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Si el archivo existe en GitHub, trae el SHA (necesario para actualizarlo)\n// Si no existe (404), sha queda null y GitHub crea el archivo nuevo\nconst ghResponse = $input.first().json;\nconst sha = ghResponse.sha || null;\n\nconst payload = $('Preparar Payload').first().json;\n\nconst body = {\n  message: payload.commit_msg,\n  content: payload.contenido_base64\n};\n\nif (sha) {\n  body.sha = sha;\n}\n\nreturn [{\n  json: {\n    github_path: payload.github_path,\n    workflow_name: payload.workflow_name,\n    es_actualizacion: !!sha,\n    body: body\n  }\n}];"
      },
      "id": "64748215-14e9-45d8-8609-5eb7bdc68d50",
      "name": "Construir Body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1168,
        -128
      ]
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "=https://api.github.com/repos/desarrollofss/n8n-backups/contents/{{ $json.github_path }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "***REDACTED***"
            },
            {
              "name": "Accept",
              "value": "***REDACTED***"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify($json.body) }}",
        "options": {}
      },
      "id": "17b13f93-3eaa-4037-8f7d-615769abbc76",
      "name": "PUT a GitHub",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1392,
        -128
      ]
    },
    {
      "parameters": {
        "jsCode": "// Log del resultado para cada workflow\nconst resultado = $input.first().json;\nconst commitUrl = resultado?.commit?.html_url || 'N/A';\nconst action = $('Construir Body').first().json.es_actualizacion ? 'Actualizado' : 'Creado';\nconst nombre = $('Construir Body').first().json.workflow_name;\n\nconsole.log(`✅ ${action}: ${nombre} → ${commitUrl}`);\n\nreturn [{ json: { accion: action, workflow: nombre, commit_url: commitUrl } }];"
      },
