          "jsCode": "const total = items.length;\nconst validos = items.length;\nconst rechazados = 0;\n\nreturn [\n  {\n    json: {\n      resumen: {\n        total_registros: total,\n        insertados: validos,\n        rechazados: rechazados\n      },\n      datos: items.map(i => i.json)\n    }\n  }\n];"
