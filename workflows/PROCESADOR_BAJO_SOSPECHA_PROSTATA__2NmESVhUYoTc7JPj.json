    {
      "parameters": {
        "jsCode": "const columnasEsperadas = [\"TIPO_DOCUMENTO\",\"DOCUMENTO\",\"NOMBRE_COMPLETO\",\"TELEFONO_1\",\"TELEFONO_2\",\"CORREO\",\"EDAD\",\"USUARIO_CONTACTADO\"];\n\nconst columnasArchivo = Object.keys(items[0].json);\n\nfor (const col of columnasEsperadas) {\n  if (!columnasArchivo.includes(col)) {\n    throw new Error(`Falta la columna: ${col}`);\n  }\n}\n\nreturn items;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        0
      ],
      "id": "20e0002c-0ade-4f17-89c4-f908f5dabcd0",
      "name": "validar_columnas"
    },
    {
      "parameters": {
        "jsCode": "const total = items.length;\nconst validos = items.length;\nconst rechazados = 0;\n\nreturn [\n  {\n    json: {\n      resumen: {\n        total_registros: total,\n        insertados: validos,\n        rechazados: rechazados\n      },\n      datos: items.map(i => i.json)\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        768,
        0
      ],
      "id": "c591c1ef-7a0c-4487-95a1-06e88753740f",
      "name": "generar_resumen"
    },
    {
      "parameters": {
        "jsCode": "// El item 0 contiene { resumen, datos }\n\nconst datos = items[0].json.datos;\n\n// Convertimos cada fila en item independiente\nreturn datos.map(fila => ({\n  json: fila\n}));\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        944,
        0
      ],
      "id": "a960a3ed-c1c2-42c3-a175-9bfbeea9ad49",
      "name": "preparar_para_insertar"
    },
    {
      "parameters": {
        "jsCode": "// Recuperar el resumen que guardamos anteriormente\nconst resumenOriginal = $node[\"generar_resumen\"].json.resumen;\n\nreturn [\n  {\n    json: {\n      status: \"ok\",\n      message: \"Archivo procesado correctamente\",\n      resumen: resumenOriginal\n    }\n  }\n];"
      },
