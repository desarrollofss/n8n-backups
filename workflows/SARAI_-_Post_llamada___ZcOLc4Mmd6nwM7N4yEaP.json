      {
        "parameters": {
          "jsCode": "const webhook = $('Webhook Retell Post-Call').first().json.body.call;\nconst paciente = $('Buscar paciente por call_id').first().json;\nconst opcionElegida = webhook.call_analysis.custom_analysis_data.opcion_elegida;\n\nconsole.log('opcion_elegida:', opcionElegida);\nconsole.log('opcion_1_raw:', paciente.opcion_1_raw);\nconsole.log('opcion_2_raw:', paciente.opcion_2_raw);\nconsole.log('opcion_3_raw:', paciente.opcion_3_raw);\n\nlet opcionRaw;\nif (opcionElegida === 'opcion_1') opcionRaw = paciente.opcion_1_raw;\nelse if (opcionElegida === 'opcion_2') opcionRaw = paciente.opcion_2_raw;\nelse if (opcionElegida === 'opcion_3') opcionRaw = paciente.opcion_3_raw;\n\nconsole.log('opcionRaw resultante:', opcionRaw);\n\nif (!opcionRaw) {\n  throw new Error(`opcionRaw es undefined. opcion_elegida recibida: \"${opcionElegida}\"`);\n}\n\nconst hora = opcionRaw.hora;\nconst hNum = parseInt(hora.split(':')[0]);\nconst meridiano = hNum < 12 ? 'am' : 'pm';\n\nreturn [{\n  json: {\n    paciente_id: paciente.id,\n    documento: paciente.documento,\n    tipo_documento: paciente.tipo_documento,\n    id_programacion: opcionRaw.idProgramacion,\n    auto_id: paciente.auto_id,\n    email: paciente.email,\n    telefono: paciente.telefono_1,\n    contrato: paciente.contrato,\n    codEmpresa: paciente.codigo_empresa,\n    fecha: opcionRaw.fecha.replace(/-/g, '/'),\n    hora: opcionRaw.hora,\n    id_medico: opcionRaw.id_medico,\n    IdPuntoAtencionCita: opcionRaw.idPuntoAntencionCita,\n    idAsunto: opcionRaw.idAsunto,\n    meridiano: meridiano,\n    opcion_elegida: opcionElegida\n  }\n}];"
        },
